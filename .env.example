# Postgres connection string (provisto por Dokploy como servicio de base de datos)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Contraseña única compartida para entrar a la app
APP_PASSWORD="cambia-esto"

# Secreto para firmar la cookie de sesión (generar con: openssl rand -hex 32)
SESSION_SECRET="cambia-esto-tambien"
